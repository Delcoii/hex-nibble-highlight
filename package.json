{
  "name": "hex-nibble-highlight",
  "displayName": "hex-nibble-highlight",
  "description": "Highlight hex literals by 4-digit(1byte)",
  "icon": "images/icon.png",
  "version": "0.0.3",
  "publisher": "Delcoii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Delcoii/hex-nibble-highlight"
  },

  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:dat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "dat",
        "aliases": ["Data", "dat"],
        "extensions": [".dat"]
      }
    ],
    "commands": [
      {
        "command": "hex-nibble-highlight.copyWithHighlight",
        "title": "Copy with Hex Highlight (for PowerPoint/Word)"
      },
      {
        "command": "hex-nibble-highlight.helloWorld",
        "title": "Hello World"
      }
    ],
    "keybindings": [
      {
        "command": "hex-nibble-highlight.copyWithHighlight",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "editorTextFocus && config.hex-nibble-highlight.richCopy && (editorLangId == c || editorLangId == cpp || editorLangId == dat || resourceExtname == .dat)"
      }
    ],
    "configuration": {
      "title": "Hex Nibble Highlight",
      "properties": {
        "hex-nibble-highlight.richCopy": {
          "type": "boolean",
          "default": true,
          "description": "Copy hex nibble colors to the clipboard (Windows: PowerPoint, Word, etc.). Uses Ctrl+C in C/C++/dat files."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
